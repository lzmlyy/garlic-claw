# 对所有文件开启自动处理
* text=auto
.gitattributes text eol=lf

# 默认让源码、配置和文档在仓库里统一使用 LF，避免 Windows 下反复出现
# “LF will be replaced by CRLF” 提示。
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.html text eol=lf
.env* text eol=lf

# 强制所有 .sh 文件在检出时使用 LF
*.sh text eol=lf

# 强制 Windows 批处理脚本在检出时使用 CRLF，避免 cmd.exe 的 label/子程序解析异常
*.bat text eol=crlf
