# Runtime
NODE_ENV=development

# HTTP
PORT=23330
CORS_ORIGIN=*
WS_PORT=23331

# Database (SQLite)
DATABASE_URL=file:./dev.db

# JWT
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string
JWT_REFRESH_EXPIRES_IN=7d

# 启动期 bootstrap 管理员账号
# 启动时若数据库中不存在该账号，会自动创建。
# BOOTSTRAP_ADMIN_EMAIL 留空时，会自动生成为 `用户名@bootstrap.local`。
# BOOTSTRAP_ADMIN_ROLE 仅支持 `super_admin` 或 `admin`，默认 `super_admin`。
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_ROLE=super_admin

# 运行时管理员覆盖（可选）
# 使用逗号分隔用户名或邮箱；命中后会在运行时直接视为 admin 或 super_admin。
# 更适合给“已经存在于数据库中的用户”做临时提权。
SUPER_ADMIN_USERNAMES=
SUPER_ADMIN_EMAILS=
ADMIN_USERNAMES=
ADMIN_EMAILS=

# AI note
# Provider and vision fallback config now live in config/ai-settings.json
# Start from config/ai-settings.example.json and create config/ai-settings.json
