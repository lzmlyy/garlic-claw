# 环境
NODE_ENV=development

# 服务器
PORT=23330
HOST=0.0.0.0

# 数据库 (SQLite)
DATABASE_URL=file:./packages/server/dev.db

# 单密钥登录 (本地运行必填，设置你自己的随机密钥)
GARLIC_CLAW_LOGIN_SECRET=your-login-secret-here
GARLIC_CLAW_AUTH_TTL=30d

# JWT (本地运行必填，每个值都需替换为独立随机密钥)
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here
JWT_REFRESH_EXPIRES_IN=7d

# AI - OpenAI (可选)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# AI - Anthropic (可选)
ANTHROPIC_API_KEY=

# AI - Ollama (可选)
OLLAMA_BASE_URL=http://localhost:11434

# 默认 AI 提供商 (openai | anthropic | ollama)
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4o

# MCP - Tavily 搜索 (可选)
TAVILY_API_KEY=

# 天气提供商 (可选)
AMAP_API_KEY=
QWEATHER_API_KEY=
