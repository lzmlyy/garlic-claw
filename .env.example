# 运行环境
NODE_ENV=development
PORT=23330
WS_PORT=23331
CORS_ORIGIN=*
DATABASE_URL=file:./dev.db

# JWT
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string
JWT_REFRESH_EXPIRES_IN=7d

# 启动期 bootstrap 管理员账号（可选）
# 启动时若数据库中不存在该账号，会自动创建。
# BOOTSTRAP_ADMIN_EMAIL 留空时，会自动生成为 `用户名@bootstrap.local`。
# BOOTSTRAP_ADMIN_ROLE 仅支持 `super_admin` 或 `admin`，默认 `super_admin`。
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_ROLE=super_admin

# 运行时管理员覆盖（可选）
# 使用逗号分隔用户名或邮箱；命中后会在运行时直接视为 admin 或 super_admin。
SUPER_ADMIN_USERNAMES=
SUPER_ADMIN_EMAILS=
ADMIN_USERNAMES=
ADMIN_EMAILS=

# 远程插件接入（可选）
REMOTE_PLUGIN_WS_URL=
REMOTE_PLUGIN_TOKEN_EXPIRES_IN=30d

# 其他说明
# AI provider 配置默认读取 packages/server/tmp/ai-settings.server.json
# 如需固定到其他路径，可自行设置 GARLIC_CLAW_AI_SETTINGS_PATH
# 如果 MCP / 自定义 provider 需要从环境变量读取密钥，可按需自行追加
