# Git 忽略文件

# Node.js 相关
node_modules/
package-lock.json
dist/
packages/*/dist/
packages/server/tmp/
workspace/
config/mcp/mcp-secrets.server.json

# TypeScript 编译产物
**/*.js.map
**/*.d.ts.map
**/*.tsbuildinfo

# 防止编译产物混入 src（shared 包曾经误生成）
packages/shared/src/**/*.js
packages/shared/src/**/*.d.ts

.env
.run.pid
*.log
coverage/
.turbo/
*.db
*.db-journal

# Python 相关
*.pyc
__pycache__/
venv/
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Skill 产物（仅本地协作使用，不提交 git）
task_plan.md
progress.md
findings.md
tmp/
docs/superpowers/
.worktrees/

# 系统自带
.DS_Store

# 其他
AGENTS.md
other/
.cache/
.playwright-mcp/
log/
.claude/

pnpm-lock.yaml
pnpm-workspace.yaml
