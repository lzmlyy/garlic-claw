generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("user")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  conversations Conversation[]
  memories      Memory[]
  automations   Automation[]
  apiKeys       ApiKey[]

  @@map("users")
}

model ApiKey {
  id         String   @id
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  keyPrefix  String   @map("key_prefix")
  secretHash String   @map("secret_hash")
  scopesJson String   @map("scopes_json")
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([userId, revokedAt])
  @@map("api_keys")
}

model Conversation {
  id              String    @id
  title           String    @default("New Chat")
  userId          String    @map("user_id")
  activePersonaId String?   @map("active_persona_id")
  hostServicesJson String?  @map("host_services_json")
  skillsJson      String?   @map("skills_json")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activePersona   Persona?  @relation("ConversationActivePersona", fields: [activePersonaId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  messages            Message[]
  imageTranscriptions ConversationImageTranscription[]

  @@map("conversations")
}

model Persona {
  id          String   @id
  name        String   @unique
  prompt      String
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  conversations Conversation[] @relation("ConversationActivePersona")

  @@map("personas")
}

model KnowledgeBaseEntry {
  id        String   @id
  title     String
  content   String
  tags      String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("knowledge_base_entries")
}

model Message {
  id             String       @id
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // system | user | assistant | tool
  content        String?
  partsJson      String?      @map("parts_json") // 原始消息 parts 的 JSON 字符串
  toolCalls      String?      @map("tool_calls") // 工具调用的 JSON 字符串
  toolResults    String?      @map("tool_results") // 工具结果的 JSON 字符串
  metadataJson   String?      @map("metadata_json") // 运行时消息 metadata 的 JSON 字符串
  provider       String?      // 使用的 AI provider
  model          String?      // 使用的 AI 模型
  status         String       @default("completed") // pending | streaming | completed | stopped | error
  error          String?      // 生成失败时的原始错误文本
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("messages")
}

model ConversationImageTranscription {
  id             String       @id
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  imageHash      String       @map("image_hash")
  mimeType       String?      @map("mime_type")
  transcription  String
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([conversationId, imageHash])
  @@map("conversation_image_transcriptions")
}

model Plugin {
  id                 String   @id
  name               String   @unique
  displayName        String?  @map("display_name")
  deviceType         String   @default("pc") @map("device_type")
  runtimeKind        String   @default("remote") @map("runtime_kind")
  description        String?
  status             String   @default("offline") // online | offline | error
  manifestJson       String?  @map("manifest_json") // PluginManifest 的 JSON 字符串
  version            String?
  config             String?  // 已保存配置的 JSON 字符串
  defaultEnabled     Boolean  @default(true) @map("default_enabled")
  conversationScopes String?  @map("conversation_scopes") // conversationId -> enabled 的 JSON 字符串
  healthStatus       String   @default("unknown") @map("health_status")
  failureCount       Int      @default(0) @map("failure_count")
  consecutiveFailures Int     @default(0) @map("consecutive_failures")
  lastError          String?  @map("last_error")
  lastErrorAt        DateTime? @map("last_error_at")
  lastSuccessAt      DateTime? @map("last_success_at")
  lastCheckedAt      DateTime? @map("last_checked_at")
  lastSeenAt         DateTime? @map("last_seen_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  events        PluginEvent[]
  storageEntries PluginStorage[]
  cronJobs      PluginCronJob[]

  @@map("plugins")
}

model PluginCronJob {
  id          String   @id
  pluginName  String   @map("plugin_name")
  plugin      Plugin   @relation(fields: [pluginName], references: [name], onDelete: Cascade)
  name        String
  cron        String
  description String?
  source      String
  enabled     Boolean  @default(true)
  dataJson    String?  @map("data_json")
  lastRunAt   DateTime? @map("last_run_at")
  lastError   String?  @map("last_error")
  lastErrorAt DateTime? @map("last_error_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([pluginName, name, source])
  @@map("plugin_cron_jobs")
}

model PluginStorage {
  id        String   @id
  pluginId  String   @map("plugin_id")
  plugin    Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  key       String
  valueJson String   @map("value_json")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([pluginId, key])
  @@map("plugin_storage")
}

model PluginEvent {
  id           String   @id
  pluginId     String   @map("plugin_id")
  plugin       Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  type         String
  level        String
  message      String
  metadataJson String?  @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("plugin_events")
}

model PluginSubagentTask {
  id                 String   @id
  pluginId           String   @map("plugin_id")
  pluginDisplayName  String?  @map("plugin_display_name")
  runtimeKind        String   @map("runtime_kind")
  userId             String?  @map("user_id")
  conversationId     String?  @map("conversation_id")
  status             String   @default("queued")
  requestJson        String   @map("request_json")
  contextJson        String   @map("context_json")
  resultJson         String?  @map("result_json")
  error              String?
  providerId         String?  @map("provider_id")
  modelId            String?  @map("model_id")
  writeBackTargetJson String? @map("write_back_target_json")
  writeBackStatus    String   @default("skipped") @map("write_back_status")
  writeBackError     String?  @map("write_back_error")
  writeBackMessageId String?  @map("write_back_message_id")
  requestedAt        DateTime @default(now()) @map("requested_at")
  startedAt          DateTime? @map("started_at")
  finishedAt         DateTime? @map("finished_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([status, requestedAt])
  @@index([pluginId, requestedAt])
  @@map("plugin_subagent_tasks")
}

model Memory {
  id        String   @id
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   // 记忆内容
  category  String   @default("general") // preference, fact, instruction, general
  keywords  String?  // 逗号分隔的搜索关键词
  createdAt DateTime @default(now()) @map("created_at")

  @@map("memories")
}

model Automation {
  id        String   @id
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  trigger   String   // JSON: { type: "cron" | "event" | "manual", cron?: string, event?: string }
  actions   String   // JSON: [{ type: "device_command" | "ai_message", plugin?: string, capability?: string, params?: {}, message?: string }]
  enabled   Boolean  @default(true)
  lastRunAt DateTime? @map("last_run_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  logs AutomationLog[]

  @@map("automations")
}

model AutomationLog {
  id           String   @id
  automationId String   @map("automation_id")
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  status       String   // success | error
  result       String?  // JSON 结果或错误消息
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("automation_logs")
}
