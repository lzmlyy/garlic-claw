{
  "name": "@garlic-claw/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch & node --watch dist/src/main.js",
    "prisma:generate": "prisma generate",
    "start": "node dist/src/main.js",
    "smoke:http": "node scripts/http-smoke.mjs",
    "test": "jest --runInBand --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@garlic-claw/plugin-sdk": "*",
    "@garlic-claw/shared": "*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.16",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "jest": "^30.3.0",
    "prisma": "^6.0.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.0"
  }
}
