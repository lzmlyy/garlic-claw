#!/bin/sh

msg_file="$1"
msg=$(cat "$msg_file")

# 取第一行
title=$(echo "$msg" | head -n1)

# 解析 prefix
prefix=$(echo "$title" | sed -E 's/^([^( :]+).*/\1/')

# 解析 scope
scope=$(echo "$title" | sed -nE 's/^[^(]+\(([^)]+)\).*/\1/p')

# 去掉前缀后的正文
body=$(echo "$title" | sed -E 's/^[^( :]+(\([^)]+\))?:[ ]*//')

# 英文 -> 中文映射
case "$prefix" in
    feat) type="新增" ;;
    fix) type="修复" ;;
    docs) type="文档" ;;
    refactor) type="重构" ;;
    chore) type="构建" ;;
    style) type="格式" ;;
    perf) type="性能" ;;
    test) type="测试" ;;
    ci) type="集成" ;;
    build) type="构建" ;;
    revert) type="回退" ;;

    新增|修复|文档|重构|构建|格式|性能|测试|集成|回退)
        type="$prefix"
        ;;
    *)
        echo "❌ 提交类型不合法"
        echo ""
        echo "允许类型："
        echo "  feat / 新增"
        echo "  fix / 修复"
        echo "  docs / 文档"
        echo "  refactor / 重构"
        echo "  chore / 构建"
        echo "  style / 格式"
        echo "  perf / 性能"
        echo "  test / 测试"
        echo "  ci / 集成"
        echo "  build / 构建"
        echo "  revert / 回退"
        echo ""
        echo "示例："
        echo "  feat(api): add login"
        echo "  新增(api): 添加登录"
        exit 1
        ;;
esac

# 构造新标题
if [ -n "$scope" ]; then
    new_title="$type($scope): $body"
else
    new_title="$type: $body"
fi

# 标题长度检查
# len=$(printf "%s" "$new_title" | wc -c)

# if [ "$len" -gt 50 ]; then
#     echo "❌ 提交标题不能超过50字符"
#     echo "当前长度: $len"
#     exit 1
# fi

# 写回 commit message
echo "$new_title" > "$msg_file"

exit 0